<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- Required by AdMob for ad personalisation opt-out -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <!-- Require Vulkan 1.0 -->
    <uses-feature android:name="android.hardware.vulkan.version"
                  android:version="0x00400000"
                  android:required="true" />
    <uses-feature android:name="android.hardware.vulkan.level"
                  android:version="0"
                  android:required="true" />

    <application
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true"
        android:label="Vlither"
        android:hasCode="true"
        android:extractNativeLibs="true"
        android:resizeableActivity="false">

        <!-- AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-9185462985805279~3500296304" />

        <!-- Opt out of AdMob data collection for GDPR safety during review -->
        <meta-data
            android:name="com.google.android.gms.ads.DELAY_APP_MEASUREMENT_INIT"
            android:value="true" />

        <!-- MainActivity: ad gate — this is the LAUNCHER entry point -->
        <activity
            android:name=".MainActivity"
            android:label="Vlither"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard|navigation"
            android:screenOrientation="sensorLandscape"
            android:exported="true"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- GameActivity: NativeActivity subclass — launched by MainActivity -->
        <activity
            android:name=".GameActivity"
            android:label="Vlither"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard|navigation"
            android:screenOrientation="sensorLandscape"
            android:immersive="true"
            android:exported="false"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen">

            <!-- Tell NativeActivity which .so to load -->
            <meta-data
                android:name="android.app.lib_name"
                android:value="vlither" />
        </activity>

    </application>

</manifest>
